Windows Registry Editor Version 5.00

[HKEY_CURRENT_USER\Software\Classes\Folder\Shell\Open in ST...]
"Icon"="C:\\Portable\\Sublime Text\\sublime_text.exe,0"
[HKEY_CURRENT_USER\Software\Classes\Folder\Shell\Open in ST...\command]
@="\"C:\\Portable\\Sublime Text\\sublime_text.exe\" \"%1\""

[HKEY_CLASSES_ROOT\*\shell\Open in ST...]
"Icon"="C:\\Portable\\Sublime Text\\sublime_text.exe,0"
[HKEY_CLASSES_ROOT\*\shell\Open in ST...\command]
@="\"C:\\Portable\\Sublime Text\\sublime_text.exe\" \"%1\""
