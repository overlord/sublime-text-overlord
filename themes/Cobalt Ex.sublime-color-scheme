{
	"name": "Cobalt Ex",
	"author": "Constantine",
	"comment": "Created by Constantine. Based on 'Cobalt' by Jacob Rus.",
	"colorSpaceName": "sRGB",
	"semanticClass": "theme.dark.cobalt",
	"globals":
	{
		"background":                  "#002240",
		"caret":                       "#FFFFFF",
		"foreground":                  "#FFFFFF",
		"invisibles":                  "#FFFFFF26",
		"line_highlight":              "#00000059",
		"selection":                   "#B36539BF",
		"brackets_foreground":         "#00E800",
		"brackets_options":            "foreground underline bold",
		"brackets_content_foreground": "#00E800",
		"brackets_contents_options":   "foreground underline bold",
	},
	"rules": [
		{
			"name": "Punctuation",
			"scope": "punctuation - (punctuation.definition.string || punctuation.definition.comment)",
			"font_style": "",
			"foreground": "#E1EFFF",
		},
		{
			"name": "Constant",
			"scope": "constant",
			"font_style": "",
			"foreground": "#FF628C",
		},
		{
			"name": "Entity",
			"scope": "entity",
			"font_style": "",
			"foreground": "#FFDD00",
		},
		{
			"name": "Keyword",
			"scope": "keyword",
			"font_style": "",
			"foreground": "#FF9D00",
		},
		{
			"name": "Storage",
			"scope": "storage",
			"font_style": "",
			"foreground": "#EDEF7D",
		},
		{
			"name": "String",
			"scope": "string -string.unquoted.old-plist -string.unquoted.heredoc -string.unquoted.plain.out.yaml, string.unquoted.heredoc string",
			"font_style": "",
			"foreground": "#3AD900",
		},

		{ //!_! зто зуб в носу для починки сломанного синтакcvса YAML
			"name": "Mapping.Key",
			"scope": "meta.mapping.key",
			"font_style": "",
			"foreground": "#FFDD00",
		},
		{ //!_! зто зуб в носу для починки сломанного синтакcvса YAML
			"name": "String",
			"scope": "string.unquoted.plain.out -meta.mapping.key",
			"font_style": "",
			"foreground": "#3AD900",
		},

		{
			"name": "Comment",
			"scope": "comment",
			"font_style": "italic",
			"foreground": "#0088FF",
		},
		{
			"name": "Support",
			"scope": "support",
			"font_style": "",
			"foreground": "#80FFBB",
		},
		{
			"name": "Variable",
			"scope": "variable",
			"font_style": "",
			"foreground": "#CCCCCC",
		},
		{
			"name": "Lang Variable",
			"scope": "variable.language",
			"font_style": "",
			"foreground": "#FF80E1",
		},
		{
			"name": "Function Call",
			"scope": "meta.function-call",
			"foreground": "#EDEF7D",
		},
		{
			"name": "Invalid",
			"scope": "invalid",
			"background": "#800F00",
			"foreground": "#F8F8F8",
		},
		{
			"name": "Embedded Source",
			"scope": "text source, string.unquoted.heredoc, source source",
			"background": "#223545",
			"font_style": "",
			"foreground": "#FFFFFF",
		},
		{
			"name": "Entity inherited-class",
			"scope": "entity.other.inherited-class",
			"font_style": "italic",
			"foreground": "#80FCFF",
		},
		{
			"name": "String embedded-source",
			"scope": "string.quoted source",
			"font_style": "",
			"foreground": "#9EFF80",
		},
		{
			"name": "String constant",
			"scope": "string constant",
			"foreground": "#80FF82",
		},
		{
			"scope": "string.punctuation",
			"foreground": "#80FFBB",
		},
		{
			"scope": "string.regexp",
			"foreground": "#80FFBB",
		},
		{
			"name": "String variable",
			"scope": "string variable",
			"foreground": "#EDEF7D",
		},
		{
			"name": "Support.function",
			"scope": "support.function",
			"font_style": "",
			"foreground": "#FFB054",
		},
		{
			"name": "Support.constant",
			"scope": "support.constant",
			"font_style": "",
			"foreground": "#EB939A",
		},
		{
			"name":  "Support.constant.variable",
			"scope": "support.constant.variable",
			"font_style":  "",
			"background": "#004260",
			"foreground": "#CCCCCC",
		},
		{
			"name": "Exception",
			"scope": "support.type.exception",
			"foreground": "#FF1E00",
		},
		{
			"name": "C# C++ Preprocessor Line",
			"scope": "meta.preprocessor.c",
			"foreground": "#8996A8",
		},
		{
			"name": "C# C++ Preprocessor Directive",
			"scope": "meta.preprocessor.c keyword",
			"foreground": "#AFC4DB",
		},
		{
			"name": "Doctype sharp;XML Processing",
			"scope": "meta.sgml.html meta.doctype, meta.sgml.html meta.doctype entity, meta.sgml.html meta.doctype string, meta.xml-processing, meta.xml-processing entity, meta.xml-processing string",
			"foreground": "#73817D",
		},
		{
			"name": "Meta.tag.A",
			"scope": "meta.tag, meta.tag entity",
			"foreground": "#9EFFFF",
		},
		{
			"name": "css tag-name",
			"scope": "meta.selector.css entity.name.tag",
			"foreground": "#9EFFFF",
		},
		{
			"name": "css#id",
			"scope": "meta.selector.css entity.other.attribute-name.id",
			"foreground": "#FFB054",
		},
		{
			"name": "css.class",
			"scope": "meta.selector.css entity.other.attribute-name.class",
			"foreground": "#5FE461",
		},
		{
			"name": "css property-name:",
			"scope": "support.type.property-name.css",
			"foreground": "#9DF39F",
		},
		{
			"name": "css property-value;",
			"scope": "meta.property-group support.constant.property-value.css, meta.property-value support.constant.property-value.css",
			"foreground": "#EDEF7D",
		},
		{
			"name": "css @at-rule",
			"scope": "meta.preprocessor.at-rule keyword.control.at-rule",
			"foreground": "#F6AA11",
		},
		{
			"name": "css additional-constants",
			"scope": "meta.property-value support.constant.named-color.css, meta.property-value constant",
			"foreground": "#EDEF7D",
		},
		{
			"name": "css constructor.argument",
			"scope": "meta.constructor.argument.css",
			"foreground": "#EB939A",
		},
		{
			"name": "Diff Header",
			"scope": "meta.diff, meta.diff.header",
			"background": "#000E1A",
			"font_style": "",
			"foreground": "#F8F8F8",
		},
